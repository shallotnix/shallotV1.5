#include <gtk/gtk.h>
#include <stdio.h>
#include <stdlib.h>
#include <math.h>
typedef struct{GtkWidget*b;GtkWidget*p;GtkWidget*r_btn;GtkWidget*l;int r;int c;guint id;gboolean active;}T;static gboolean u(gpointer d){T*t=(T*)d;if(!t->active)return 1;t->r--;if(t->r>0){char s[64];sprintf(s,"Time: %02d:%02d",t->r/60,t->r%60);gtk_button_set_label(GTK_BUTTON(t->b),s);return 1;}else{gtk_button_set_label(GTK_BUTTON(t->b),"STRAT TIME : ");gtk_button_set_label(GTK_BUTTON(t->p),"Pause");gtk_widget_set_sensitive(t->b,1);gtk_widget_set_sensitive(t->p,0);t->c++;char s[64];sprintf(s,"عدد المرات الناجحة: %d",t->c);gtk_label_set_text(GTK_LABEL(t->l),s);system("pw-play --volume=0.2 --frequency=440 --duration=0.5 /dev/zero -q 2>/dev/null || paplay /run/current-system/sw/share/sounds/alsa/Front_Center.wav -q 2>/dev/null || speaker-test -t sine -f 440 -l 1 2>/dev/null &");GtkAlertDialog*g=gtk_alert_dialog_new("تنبيه");gtk_alert_dialog_set_detail(g,"انظر بعيد عن شاشة  لمدة 20 ثانيه ");gtk_alert_dialog_show(g,GTK_WINDOW(gtk_widget_get_root(t->b)));g_object_unref(g);if(t->id){g_source_remove(t->id);t->id=0;}t->active=0;return 0;}}
static void alal(GtkWidget*w,gpointer d){T*t=(T*)d;if(t->id)return;int m=1;while(m<=1000){printf("%d\n",m);++m;}gtk_widget_set_sensitive(w,0);gtk_widget_set_sensitive(t->p,1);gtk_widget_set_sensitive(t->r_btn,1);t->r=1200;t->active=1;gtk_button_set_label(GTK_BUTTON(w),"Time: 20:00");gtk_button_set_label(GTK_BUTTON(t->p),"Pause");t->id=g_timeout_add(1000,u,t);}
static void toggle_p(GtkWidget*w,gpointer d){T*t=(T*)d;if(!t->id)return;t->active=!t->active;gtk_button_set_label(GTK_BUTTON(w),t->active?"Pause":"Resume");}
static void reset_t(GtkWidget*w,gpointer d){T*t=(T*)d;if(t->id){g_source_remove(t->id);t->id=0;}t->active=0;t->r=1200;gtk_button_set_label(GTK_BUTTON(t->b),"STRAT TIME : ");gtk_button_set_label(GTK_BUTTON(t->p),"Pause");gtk_widget_set_sensitive(t->b,1);gtk_widget_set_sensitive(t->p,0);gtk_widget_set_sensitive(t->r_btn,0);}
static void activate(GtkApplication*a,gpointer d){GtkWidget*w=gtk_application_window_new(a),*box=gtk_box_new(GTK_ORIENTATION_VERTICAL,10);T*t=g_new0(T,1);t->b=gtk_button_new_with_label("STRAT TIME : ");t->p=gtk_button_new_with_label("Pause");t->r_btn=gtk_button_new_with_label("Reset");t->l=gtk_label_new("عدد المرات : 0");t->c=0;gtk_widget_set_sensitive(t->p,0);gtk_widget_set_sensitive(t->r_btn,0);gtk_window_set_title(GTK_WINDOW(w),"shallotv1.5");gtk_window_set_default_size(GTK_WINDOW(w),250,250);gtk_widget_set_halign(box,GTK_ALIGN_CENTER);gtk_widget_set_valign(box,GTK_ALIGN_CENTER);g_signal_connect(t->b,"clicked",G_CALLBACK(alal),t);g_signal_connect(t->p,"clicked",G_CALLBACK(toggle_p),t);g_signal_connect(t->r_btn,"clicked",G_CALLBACK(reset_t),t);gtk_box_append(GTK_BOX(box),t->b);gtk_box_append(GTK_BOX(box),t->p);gtk_box_append(GTK_BOX(box),t->r_btn);gtk_box_append(GTK_BOX(box),t->l);gtk_window_set_child(GTK_WINDOW(w),box);gtk_window_present(GTK_WINDOW(w));}
int main(int g,char**v){GtkApplication*a=gtk_application_new("org.gtk.example",G_APPLICATION_DEFAULT_FLAGS);g_signal_connect(a,"activate",G_CALLBACK(activate),NULL);int s=g_application_run(G_APPLICATION(a),g,v);g_object_unref(a);return s;}

